generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     String @default("USER")
}

model Product {
  id String @id @default(uuid())

  title            String
  description      String?
  shortDescription String?

  slug String @default("")

  // retail | made_to_order | rental | resale
  mode String @default("retail")

  category String?
  brand    String?
  vendor   String?
  color    String?
  fabric   String?
  occasion String?

  composition String?
  style       String?
  print       String?
  badge       String?

  primaryCollection   String?
  secondaryCollection String?

  // Product detail metadata
  categories       String[] @default([])
  tags             String[] @default([])
  careInstructions String[] @default([])

  // Pricing
  basePrice       Float?
  compareAtPrice  Float?
  discountPercent Int?
  currency        String @default("USD")

  // MTO
  productionType String @default("READY_STOCK")
  // READY_STOCK | MADE_TO_ORDER | HYBRID

  isMadeToOrder          Boolean @default(false)
  allowCustomSizing      Boolean @default(false)
  allowRushProduction    Boolean @default(false)
  standardLeadTimeDays   Int     @default(21)
  rushLeadTimeDays       Int?
  rushFee                Float?
  customSizingFinalSale  Boolean @default(false)

  // Availability
  availabilityStatus String @default("in_stock")
  // in_stock | low_stock | out_of_stock | preorder | made_to_order

  availabilityLabel String?
  lowStockThreshold Int @default(3)

  // Marketing / urgency
  soldInLastHours Int?
  soldHoursWindow Int?
  viewingNow      Int?
  rating          Float?
  reviewCount     Int?

  // Delivery
  estimatedDomestic      String?
  estimatedInternational String?
  pickupAvailable        Boolean @default(false)
  pickupReadyIn          String?

  // Returns
  returnWindowDays Int?
  returnText       String?
  isFinalSale      Boolean @default(false)

  // Store / vendor info
  storeName           String?
  storeLocation       String?
  storeAddress        String?
  storePickupAvailable Boolean @default(false)

  // Tabs content
  tabDescription      String?
  tabCompositionCare  String?
  tabShippingReturns  String?
  tabReturnPolicies   String?

  // Reviews summary
  reviewsAverage Float?
  reviewsTotal   Int?
  review5Count   Int @default(0)
  review4Count   Int @default(0)
  review3Count   Int @default(0)
  review2Count   Int @default(0)
  review1Count   Int @default(0)

  // Size guide
  sizeGuideUnit String @default("inches")

  // Payment icons/config
  paymentMethods String[] @default([])

  status String @default("active")

  seoTitle       String?
  seoDescription String?

  printSwatch String?

  embedding Float[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  variants ProductVariant[]
  images   ProductImage[]
  colors   ProductColor[]
  reviews  ProductReview[]

  relatedProducts ProductRelatedProduct[] @relation("RelatedProductSource")
  relatedTo        ProductRelatedProduct[] @relation("RelatedProductTarget")
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  size  String
  color String?

  chest   Float
  waist   Float
  length  Float
  fitType String // slim | regular | oversized

  price          Float
  compareAtPrice Float?
  stock          Int

  sku     String @unique
  barcode String?

  weight     Float?
  weightUnit String?

  isAvailable Boolean @default(true)

  // READY_STOCK | MADE_TO_ORDER
  isShipsNow    Boolean @default(false)
  productionType String @default("READY_STOCK")

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([color])
  @@index([size])
}

model ProductImage {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url       String
  alt       String?
  isPrimary Boolean @default(false)
  position  Int     @default(0)

  // Optional: image can belong to a color swatch/gallery
  colorName String?

  @@index([productId])
  @@index([position])
}

model ProductColor {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name       String
  hex        String?
  imageUrl   String?
  isSelected Boolean @default(false)
  position   Int     @default(0)

  createdAt DateTime @default(now())

  @@index([productId])
  @@unique([productId, name])
}

model ProductReview {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  title     String?
  rating    Int
  comment   String?
  author    String?
  images    String[] @default([])

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([rating])
}

model ProductRelatedProduct {
  id String @id @default(uuid())

  productId        String
  relatedProductId String

  product        Product @relation("RelatedProductSource", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("RelatedProductTarget", fields: [relatedProductId], references: [id], onDelete: Cascade)

  position Int @default(0)

  createdAt DateTime @default(now())

  @@unique([productId, relatedProductId])
  @@index([productId])
  @@index([relatedProductId])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String
  items     CartItem[]
  createdAt DateTime   @default(now())
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int

  variantId String?

  sizeType String @default("STANDARD")
  // STANDARD | CUSTOM

  bust Float?
  waist Float?
  hips Float?
  hollowToFloor Float?
  heightBareFoot Float?
  extraLength Float?

  customSizingAccepted Boolean @default(false)

  deliveryOption String @default("STANDARD")
  // STANDARD | RUSH

  estimatedArrivalStart DateTime?
  estimatedArrivalEnd   DateTime?

  cart Cart @relation(fields: [cartId], references: [id])
}

model Order {
  id         String   @id @default(uuid())
  userId     String
  total      Float

  status     String   @default("PENDING") // PENDING | PAID | FAILED

  paymentId  String?  // Stripe PaymentIntent ID

  items      OrderItem[]

  createdAt  DateTime @default(now())

  // ✅ FIX: temporary default add karo
  updatedAt  DateTime @default(now()) @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  variantId String?

  sizeType String @default("STANDARD")

  bust Float?
  waist Float?
  hips Float?
  hollowToFloor Float?
  heightBareFoot Float?
  extraLength Float?

  customSizingAccepted Boolean @default(false)

  productionType String @default("READY_STOCK")
  // READY_STOCK | MADE_TO_ORDER

  deliveryOption String @default("STANDARD")
  // STANDARD | RUSH

  estimatedArrivalStart DateTime?
  estimatedArrivalEnd   DateTime?

  finalSale Boolean @default(false)

  order Order @relation(fields: [orderId], references: [id])
}

model BridalPartyEvent {
  id              String   @id @default(uuid())
  organizerUserId String
  name            String
  eventDate       DateTime
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
}

model BridalPartyMember {
  id        String @id @default(uuid())
  eventId  String
  userId   String?
  email    String
  name     String?
  role     String
  status   String @default("invited")
  size       String?
  preference String?

  createdAt DateTime @default(now())
}

model BridalPartySelection {
  id        String @id @default(uuid())
  eventId   String
  memberId  String
  productId String
  variantId String?
  status    String // assigned | selected | approved | rejected

  createdAt DateTime @default(now())
}

model BridalPartyPayment {
  id                    String @id @default(uuid())
  eventId               String
  memberId              String
  amount                Int
  status                String // pending | paid | failed
  stripePaymentIntentId String?

  createdAt DateTime @default(now())
}

model BridalPartyInvite {
  id        String   @id @default(uuid())
  eventId   String
  email     String
  token     String   @unique
  status    String   // sent | accepted | expired
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Shipment {
  id             String         @id @default(uuid())
  eventId        String?
  orderId        String
  status         String
  trackingNumber String?
  carrier        String?
  createdAt      DateTime       @default(now())

  items          ShipmentItem[]
}

model ShipmentItem {
  id         String   @id @default(uuid())
  shipmentId String
  memberId   String
  productId  String
  status     String

  shipment   Shipment @relation(fields: [shipmentId], references: [id])
}

model UserProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  height         Float?
  weight         Float?
  chest          Float?
  waist          Float?
  bodyType       String?  // slim | average | broad
  fitPreference  String?  // slim | regular | loose
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FitFeedback {
  id        String   @id @default(uuid())
  userId    String
  productId String
  size      String
  result    String   // too_small | perfect | too_large
  issueArea String?
  createdAt DateTime @default(now())
}