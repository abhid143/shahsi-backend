generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  role     String @default("USER")
}

model Product {
  id          String   @id @default(cuid())

  title       String
  description String?

  slug String @default("")

  category    String?
  brand       String?
  color       String?
  fabric      String?
  occasion    String?

  // 🔥 NEW FIELDS
  composition  String?
  style        String?
  print        String?
  badge        String?

  primaryCollection   String?
  secondaryCollection String?

  basePrice   Float?
  currency    String @default("USD")

  status      String @default("active")

  seoTitle        String?
  seoDescription  String?

  printSwatch     String?

  embedding   Float[]

  createdAt   DateTime @default(now())
  updatedAt DateTime @default(now())

  variants    ProductVariant[]
  images      ProductImage[]
}

model ProductVariant {
  id        String   @id @default(cuid())

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  size      String

  price         Float
  compareAtPrice Float?

  stock     Int

  sku       String   @unique
  barcode   String?

  weight    Float?
  weightUnit String?

  createdAt DateTime @default(now())
}

model ProductImage {
  id        String   @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url       String
  alt       String?
  isPrimary Boolean @default(false)
}


model Cart {
  id        String     @id @default(cuid())
  userId    String
  items     CartItem[]
  createdAt DateTime   @default(now())
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int

  cart Cart @relation(fields: [cartId], references: [id])
}

model Order {
  id         String   @id @default(cuid())
  userId     String
  total      Float

  status     String   @default("PENDING") // PENDING | PAID | FAILED

  paymentId  String?  // Stripe PaymentIntent ID

  items      OrderItem[]

  createdAt  DateTime @default(now())

  // ✅ FIX: temporary default add karo
  updatedAt  DateTime @default(now()) @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order Order @relation(fields: [orderId], references: [id])
}

model BridalPartyEvent {
  id              String   @id @default(cuid())
  organizerUserId String
  name            String
  eventDate       DateTime
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
}

model BridalPartyMember {
  id        String @id @default(uuid())
  eventId  String
  userId   String?
  email    String
  name     String?
  role     String
  status   String @default("invited")
  size       String?
  preference String?

  createdAt DateTime @default(now())
}

model BridalPartySelection {
  id        String @id @default(uuid())
  eventId   String
  memberId  String
  productId String
  variantId String?
  status    String // assigned | selected | approved | rejected

  createdAt DateTime @default(now())
}

model BridalPartyPayment {
  id                    String @id @default(uuid())
  eventId               String
  memberId              String
  amount                Int
  status                String // pending | paid | failed
  stripePaymentIntentId String?

  createdAt DateTime @default(now())
}

model BridalPartyInvite {
  id        String   @id @default(uuid())
  eventId   String
  email     String
  token     String   @unique
  status    String   // sent | accepted | expired
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Shipment {
  id             String         @id @default(uuid())
  eventId        String
  orderId        String
  status         String
  trackingNumber String?
  carrier        String?
  createdAt      DateTime       @default(now())

  items          ShipmentItem[]
}

model ShipmentItem {
  id         String   @id @default(uuid())
  shipmentId String
  memberId   String
  productId  String
  status     String

  shipment   Shipment @relation(fields: [shipmentId], references: [id])
}